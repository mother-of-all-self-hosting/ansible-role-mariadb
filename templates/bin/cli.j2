#!/bin/bash

{{ devture_systemd_docker_base_host_command_docker }} run \
    -it \
    --rm \
    --user={{ mariadb_uid }}:{{ mariadb_gid }} \
    --cap-drop=ALL \
    --mount type=bind,src={{ mariadb_base_path }}/my.cnf,dst=/my.cnf,ro \
    {% if mariadb_cli_use_unix_socket_enabled %}
    --mount type=bind,src={{ mariadb_run_path }},dst={{ mariadb_run_path_in_container }} \
    {% else %}
    --network={{ mariadb_container_network }} \
    {% endif %}
    {{ mariadb_container_image_to_use }} \
    {{ mariadb_binary_name_shell }} --defaults-file=/my.cnf \
    {% if mariadb_cli_use_unix_socket_enabled %}
    --socket={{ mariadb_run_path_in_container }}/mysqld.sock \
    {% else %}
    -h {{ mariadb_connection_hostname }} \
    {% endif %}
    {{ mariadb_db_name }}
